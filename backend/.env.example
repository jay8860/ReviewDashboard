# JWT Secret (change this in production!)
SECRET_KEY=change-me-in-production

# Database (leave blank to use SQLite at /app/backend/data/governance.db)
# DATABASE_URL=postgresql://user:pass@host/dbname

# Email (optional - for password reset)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_email_app_password
BASE_URL=https://your-railway-app.up.railway.app

# Gemini AI document analysis
GEMINI_API_KEY=your_gemini_api_key
# Optional: gemini-2.5-flash | gemini-2.5-flash-lite | gemini-2.0-flash
GEMINI_MODEL=gemini-2.5-flash
# Optional extraction cap
DOC_ANALYSIS_MAX_CHARS=140000
